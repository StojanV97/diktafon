# Transcription: "local" (private, no network) or "openai" (cloud)
TRANSCRIPTION_ENGINE=local
# Model size for local: tiny, base, small, medium, large
# "small" recommended for Serbian (good diacritics handling, moderate speed)
WHISPER_MODEL_SIZE=small
# Only needed if TRANSCRIPTION_ENGINE=openai
OPENAI_API_KEY=your_openai_api_key_here
# Only needed for AssemblyAI folders (speaker diarization)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
